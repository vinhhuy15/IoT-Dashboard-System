# ============================================================
# Smart City Dashboard - Configuration Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NOTE: This project uses hardcoded config in script.js and
# IOT_WOKWI/src/main.cpp. Update those files directly with
# your credentials. This file serves as documentation only.
# ============================================================

# ----- Firebase Configuration -----
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ----- Groq AI Configuration -----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# ----- WiFi Configuration (ESP32) -----
WIFI_SSID=Wokwi-GUEST
WIFI_PASSWORD=

# ----- Face ID Configuration -----
FACE_DESCRIPTOR_STORAGE_KEY=smartcity_face_descriptor_v1
FACE_MATCH_THRESHOLD=0.38
FACE_MIN_SAMPLES=3
FACE_MAX_SAMPLES=6
